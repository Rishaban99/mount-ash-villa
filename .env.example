# Required — MongoDB Atlas connection string (Prisma ORM)
DATABASE_URL="mongodb+srv://user:password@cluster.mongodb.net/hotel"

# Required — JWT signing secret for httpOnly session cookies
SESSION_SECRET=generate-a-long-random-string

# Optional — override seeded super-admin credentials on first seed
NEXT_PUBLIC_INITIAL_SUPER_ADMIN_USERNAME=admin
INITIAL_SUPER_ADMIN_PASSWORD=changeme
NEXT_PUBLIC_INITIAL_SUPER_ADMIN_NAME=Super Admin
